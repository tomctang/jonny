66b37ce6181d"],

Cell["\<\
keywords : sequences/series, finite differences, sums/products, gfun
e . g . Finite Sums / Infinite Sums,    Riemann Sums\
\>", "Text",
 CellChangeTimes->{
  3.9808764170281067`*^9, {3.9808768088240013`*^9, 
   3.980876820095667*^9}},ExpressionUUID->"f25d9ee3-1674-4b7f-b56a-\
d2d59b295947"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"k", "=", "0"}], "5"], "k"}], "  "}], "\[IndentingNewLine]", 
 RowBox[{
  UnderoverscriptBox["\[Sum]", 
   RowBox[{"k", "=", "1"}], "\[Infinity]"], 
  RowBox[{"1", "/", 
   RowBox[{"2", "^", "k"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "x_", "]"}], "=", 
   RadicalBox[
    RowBox[{"x", "-", "1"}], "3"]}], ";", " ", 
  RowBox[{"plot", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "3"}], "}"}], ",", 
     RowBox[{"AspectRatio", "->", "Automatic"}], ",", 
     RowBox[{"PlotTheme", "->", "\"\<Detailed\>\""}]}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"DiscretePlot", "[", 
    RowBox[{
     RowBox[{"f", "[", "x", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "1", ",", "3", ",", 
       RowBox[{"1", "/", "3"}]}], "}"}], ",", 
     RowBox[{"ExtentSize", "->", "Full"}]}], "]"}], ",", "plot"}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9808760978542337`*^9, 3.9808761594348*^9}, {
   3.980876214937421*^9, 3.9808762919117117`*^9}, {3.980876323645145*^9, 
